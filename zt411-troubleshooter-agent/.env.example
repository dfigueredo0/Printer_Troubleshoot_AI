# Copy to .env and fill in values before running.
# The agent works fully offline (Tier 0) with no env vars set.

# ── LLM / Planner ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-... # Anthropic API key — required for Tier 2 (cloud) planner

# ── Database ─────────────────────────────────────────────────────
USE_DB=false # Set USE_DB=true to persist sessions in PostgreSQL instead of in-memory
DATABASE_URL=

# PostgreSQL password (used by docker compose)
POSTGRES_DB=
POSTGRES_PASSWORD=

# ── Frontend ─────────────────────────────────────────────────────
# Backend API URL for the Next.js console (defaults to http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000
