{
  "name": "ruflo-agent-framework",
  "version": "0.1.0",
  "description": "Comprehensive AI agent orchestration framework built on Claude Code",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration",
    "test:performance": "vitest run src/tests/performance",
    "test:e2e": "vitest run src/tests/e2e",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' --max-warnings 0",
    "validate": "bash .claude/helpers/validate-config.sh",
    "adr:check": "bash .claude/helpers/adr-compliance.sh force",
    "ddd:track": "bash .claude/helpers/ddd-tracker.sh force",
    "security:scan": "bash .claude/helpers/security-scanner.sh run",
    "benchmark": "vitest run src/tests/performance --reporter=verbose",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "vitest": "^1.6.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0"
  },
  "dependencies": {
    "ruflo": "latest",
    "ruv-swarm": "latest"
  }
}
